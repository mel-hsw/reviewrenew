# Use KEY=value with no spaces around "=" so all parsers load reliably.
OPENAI_API_KEY=sk-your-key-here
OPENAI_TEXT_MODEL=gpt-5.4-mini
# Optional: separate model for Q3 creative text-to-image prompt writing (defaults to OPENAI_TEXT_MODEL).
# OPENAI_Q3_TEXT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Q3 image generation: explicit provider + model id (outputs go to outputs/<ASIN>/openai/ and .../gemini/).
OPENAI_IMAGE_MODEL=chatgpt-image-latest
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_API_KEY=your-google-ai-studio-key

# Legacy aliases (optional): OPENAI_IMAGE_MODEL_PRIMARY overrides nothing if OPENAI_IMAGE_MODEL is set.
# If GEMINI_IMAGE_MODEL is omitted, OPENAI_IMAGE_MODEL_SECONDARY=gemini-* is still read for migration.

# Optional — Gemini 3.x output size: 512 | 1K | 2K | 4K
# GEMINI_IMAGE_RESOLUTION=1K

# Optional — appended after each RAG shot prompt for that provider only (shared base + light tuning).
# OPENAI_IMAGE_PROMPT_SUFFIX="Emphasize crisp commercial lighting and a catalog-ready composition."
# GEMINI_IMAGE_PROMPT_SUFFIX="Render as one coherent photographic scene; single clear focal subject."

# To run OpenAI only, set: GEMINI_IMAGE_MODEL=
# Optional: 1024x1024, 1536x1024, 1024x1536, auto (GPT image models)
OPENAI_IMAGE_SIZE=1024x1024
# Optional. GPT image: low|medium|high|auto. dall-e-3: standard|hd. Leave unset for API defaults.
# OPENAI_IMAGE_QUALITY=auto

# RAG chunking (Q2): sliding | paragraph_batch
# Default in repo .env: paragraph_batch — most Amazon reviews here are short; paragraph packing
# preserves whole review bodies when they fit under CHUNK_MAX_TOKENS (sliding is better for long narratives).
# CHUNK_STRATEGY=paragraph_batch
# CHUNK_MAX_TOKENS=400
# CHUNK_OVERLAP_TOKENS=60
